# ============================================================
#  Zsh 설정 파일 (~/.zshrc)
#  터미널을 열 때마다 자동으로 읽힙니다.
# ============================================================

# ------------------------------------------------------------
#  플러그인 (Homebrew로 설치)
# ------------------------------------------------------------

# 자동완성 제안: 이전에 입력한 명령을 회색으로 미리 보여줌 (→ 키로 수락)
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh

# 문법 하이라이트: 유효한 명령은 초록색, 오타는 빨간색으로 표시
# (주의) syntax-highlighting은 항상 맨 마지막에 source 해야 정상 작동
source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# ------------------------------------------------------------
#  도구 초기화
# ------------------------------------------------------------

# fzf: Ctrl+R(명령 히스토리 검색) 등 퍼지 검색 기능 (파일이 있을 때만 로드)
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# mise: node/python/java 등 런타임 버전 관리자 활성화
# (폴더별 .mise.toml 을 읽어 자동으로 버전 전환)
eval "$(mise activate zsh)"

# ------------------------------------------------------------
#  키 바인딩 (macOS 터미널에서 기본으로 안 먹는 키 살리기)
# ------------------------------------------------------------

bindkey "^[[H"  beginning-of-line   # Home  → 줄 맨 앞으로
bindkey "^[[F"  end-of-line         # End   → 줄 맨 끝으로
bindkey "^[[1~" beginning-of-line   # Home  (다른 터미널용 코드)
bindkey "^[[4~" end-of-line         # End   (다른 터미널용 코드)
bindkey "^[[3~" delete-char         # Delete → 커서 뒤 글자 삭제
